FROM golang:1.22-alpine AS builder
WORKDIR /app
COPY go.mod ./
RUN go mod download
COPY *.go ./
RUN CGO_ENABLED=0 GOOS=linux go build -o /client .

FROM alpine:3.19
RUN apk add --no-cache iproute2 iptables bash
COPY --from=builder /client /client
COPY netem.sh /netem.sh
RUN chmod +x /netem.sh
ENTRYPOINT ["/client"]
