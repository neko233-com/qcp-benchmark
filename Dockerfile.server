FROM golang:1.22-alpine AS builder
WORKDIR /src
COPY qcp-lib-go/go.mod qcp-lib-go/go.sum* /src/qcp-lib-go/
COPY qcp-lib-go/qcp/ /src/qcp-lib-go/qcp/
COPY qcp-benchmark/go.mod qcp-benchmark/go.sum* /src/qcp-benchmark/
WORKDIR /src/qcp-benchmark
RUN go mod download
COPY qcp-benchmark/*.go /src/qcp-benchmark/
RUN CGO_ENABLED=0 GOOS=linux go build -o /server .

FROM alpine:3.19
RUN apk add --no-cache iproute2
COPY --from=builder /server /server
EXPOSE 9000 9001 9002 9003
ENTRYPOINT ["/server"]
